      "allow_qint2_overrides": true
    },

    "Phantom_QINT2_Backup": {
      "type": "PhantomLayer",
      "quantization": "Q_INT2",
      "activation": "on-demand",
      "shadow_copy": true,
      "dynamic_scaling": true,
      "vram_virtualized": true,
      "priority": "failsafe",
      "ucb1_visible": false,
      "description": "Ultra-compact QINT2 phantom layer for backup and crash recovery"
