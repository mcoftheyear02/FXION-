action               = PBO_BOOST + VRAM_DEFRAG + CLOCK_RELOCK
pbo_offset_mhz       = +200
thermal_limit_C      = 83
affect_layers        = 7-12

[SELF_HEAL_19_NEUTRINOS_OI_ISO]
